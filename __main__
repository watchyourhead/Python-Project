import math

class FinancialLogic:
    """
    Financial functions containing subtle logic errors for student analysis.
    """

    #Congrats Wei Qing

    @staticmethod
    def calculate_compound_interest(principal, annual_rate, years, compounding_freq=12):
        """
        Calculates the future value of an investment.
        """
        if principal < 0:
            raise ValueError("Principal cannot be negative.")
        
        amount = principal * (1 + (annual_rate / compounding_freq)) ** (compounding_freq * years)
        
        return round(amount, 2)

    @staticmethod
    def calculate_total_interest(principal, future_value):
        """
        Calculates total interest earned.
        """
        return round(future_value - principal, 2)


def get_float(prompt, min_value=None, allow_zero=True):
    while True:
        try:
            value = float(input(prompt).strip())
            if min_value is not None:
                if allow_zero and value < min_value:
                    raise ValueError
                if not allow_zero and value <= min_value:
                    raise ValueError
            return value
        except ValueError:
            if min_value is None:
                print("Please enter a valid number.")
            elif allow_zero:
                print(f"Please enter a number greater than or equal to {min_value}.")
            else:
                print(f"Please enter a number greater than {min_value}.")


def get_int(prompt, min_value=None, default=None):
    while True:
        raw = input(prompt).strip()
        if raw == "" and default is not None:
            return default
        try:
            value = int(raw)
            if min_value is not None and value < min_value:
                raise ValueError
            return value
        except ValueError:
            if default is not None:
                print(f"Please enter an integer greater than or equal to {min_value}, or press Enter to use {default}.")
            else:
                print(f"Please enter an integer greater than or equal to {min_value}.")


def main():
    print("Compound Interest Calculator")

    principal = get_float("Enter the principal amount: ", min_value=0.0)
    annual_rate = get_float("Enter the annual interest rate: ", min_value=0.0)
    years = get_float("Enter the number of years: ")
    compounding_freq = get_int("Enter the compounding frequency per year [press Enter for 12]: ", min_value=1, default=12)

    try:
        future_value = FinancialLogic.calculate_compound_interest(
            principal,
            annual_rate,
            years,
            compounding_freq=compounding_freq,
        )
        total_interest = FinancialLogic.calculate_total_interest(principal, future_value)

        print(f"\nFuture value: ${future_value:.2f}")
        print(f"Total interest earned: ${total_interest:.2f}")
    except ValueError as exc:
        print(f"Error: {exc}")


if __name__ == "__main__":
    main()